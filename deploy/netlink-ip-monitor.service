[Unit]
Description=NetLink IP sharing monitor
After=network.target netlink-bot.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/netlink-bot
ExecStart=/usr/bin/python3 -m bot.services.ip_monitor
StandardOutput=append:/var/log/netlink-ip-monitor.log
StandardError=append:/var/log/netlink-ip-monitor.log
